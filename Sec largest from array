public class Main
{
	public static void main(String[] args) {
	    int[] arr={10,20,30,20,50};
	    int max=arr[0];
	    for(int i=0;i<arr.length;i++){
	        if(arr[i]>max){
	            max=arr[i];
	        }
	        
	    }
	    int secmax=arr[0];
	    for(int i=0;i<arr.length;i++){
	        if(arr[i]>secmax && arr[i] <max){
	            secmax=arr[i];
	        }
	    }
	    System.out.println(secmax);
	    
	
	}
	
}
